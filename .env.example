# ─────────────────────────────────────────────────────────────────────────────
# DealFinder — copy this file to ".env" and fill in your keys.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (the only data store — get these from your Supabase project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Settings → Database → Connection string → "Direct connection" (port 5432, includes the password)
DIRECT_URL=postgresql://postgres:PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres

# CapSolver — solves the county clerk's reCAPTCHA (https://capsolver.com)
CAPSOLVER_API_KEY=your-capsolver-key

# Apify — reliable Zillow valuation at scale (https://apify.com → Settings → Integrations → API token)
APIFY_API_TOKEN=your-apify-token

# Anthropic — fallback OCR for scrambled-font "Value of Real Property" forms (optional but recommended)
ANTHROPIC_API_KEY=your-anthropic-key

# Google Sheet live sync via n8n webhook (OPTIONAL — leave blank to skip the sheet)
SHEET_WEBHOOK_URL=

# County label stored on each lead (single-scan default; daily.mjs uses ENABLED_COUNTIES instead)
COUNTY=Orange

# Counties the daily run scans (comma-separated). Both Orange + Seminole are live.
ENABLED_COUNTIES=Orange,Seminole
# Daily run pulls NEW foreclosures from the last N days (dedups via upsert; covers weekends/missed runs).
DAILY_DAYS=3

# ── Daily Telegram report (the door-knock alert Dyer gets every morning) ──────
# 1) In Telegram, message @BotFather → /newbot → name it → copy the token below.
# 2) Get the chat id: message your new bot once, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id": ... }
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Set to 0 to stay silent on days with no new doors (default 1 = send a short "ran, nothing new" heartbeat)
NOTIFY_HEARTBEAT=1
