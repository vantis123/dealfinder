# ─────────────────────────────────────────────────────────────────────────────
# DealFinder — copy this file to ".env" and fill in your keys.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Web auth gate (REQUIRED) ──────────────────────────────────────────────────
# Every page + /api/* route is gated behind HTTP Basic auth (middleware.ts).
# The dashboard exposes real owner PII and can trigger paid scraper runs, so if
# these are UNSET the app fails closed and returns 401 for everything.
# Set both in your host (Railway/Vercel) env, then log in via the browser prompt.
DEALFINDER_AUTH_USER=pick-a-username
DEALFINDER_AUTH_PASS=pick-a-strong-password

# Supabase (the only data store — get these from your Supabase project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Settings → Database → Connection string → "Direct connection" (port 5432, includes the password)
DIRECT_URL=postgresql://postgres:PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres

# CapSolver — solves the county clerk's reCAPTCHA (https://capsolver.com)
CAPSOLVER_API_KEY=your-capsolver-key

# Apify — reliable Zillow valuation at scale (https://apify.com → Settings → Integrations → API token)
APIFY_API_TOKEN=your-apify-token

# Anthropic — fallback OCR for scrambled-font "Value of Real Property" forms (optional but recommended)
ANTHROPIC_API_KEY=your-anthropic-key

# Google Sheet live sync via n8n webhook (OPTIONAL — leave blank to skip the sheet)
SHEET_WEBHOOK_URL=

# County label stored on each lead (single-scan default; daily.mjs uses ENABLED_COUNTIES instead)
COUNTY=Orange

# Pre-foreclosure counties the daily run scans (comma-separated). All 7 are live.
ENABLED_COUNTIES=Orange,Seminole,Lake,Polk,Volusia,Brevard,Osceola
# Daily run pulls NEW foreclosures from the last N days (dedups via upsert; covers weekends/missed runs).
DAILY_DAYS=3

# ── Auctions (RealForeclose scheduled sales) ─────────────────────────────────
# Your RealForeclose bidder login (used only to read the public sale calendar).
REALFORECLOSE_USER=
REALFORECLOSE_PASS=
# Auction counties the daily run scans. Live: Seminole, Orange, Volusia, Polk.
AUCTION_COUNTIES=Seminole,Orange,Volusia,Polk
# How many months of the sale calendar to walk forward each run.
AUCTION_MONTHS_AHEAD=6

# ── CRM behavior ─────────────────────────────────────────────────────────────
# 1 (default) = finds auto-flow into the CRM pipeline; set 0 to keep them in the source tables only.
AUTO_PROMOTE_CRM=1
# From a cloud host whose direct Supabase host is IPv6-only, set the IPv4 pooler URL here
# (Supabase → Settings → Database → Connection pooling, "Session" mode, port 5432). Leave blank locally.
SUPABASE_DB_POOL_URL=

# ── Daily Telegram report (the door-knock alert Dyer gets every morning) ──────
# 1) In Telegram, message @BotFather → /newbot → name it → copy the token below.
# 2) Get the chat id: message your new bot once, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id": ... }
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Set to 0 to stay silent on days with no new doors (default 1 = send a short "ran, nothing new" heartbeat)
NOTIFY_HEARTBEAT=1

# Resend — sends the "your county is live" email (get a key at resend.com, verify your domain)
RESEND_API_KEY=your-resend-key
RESEND_FROM=DealFinder <support@yourdomain.com>
